# Скопируйте в railway.local.env и вставьте токен (файл в .gitignore).
#
# Токены Railway (любой подойдёт для CLI; для CI часто используют Project Token):
#   • Аккаунт: https://railway.app/account/tokens  → New token
#   • Проект:  Project → Settings → Tokens → создать Project token
#
# НЕ коммитьте railway.local.env и НЕ вставляйте токен в чат с ИИ.

RAILWAY_TOKEN=

# Опционально: если не делали `railway link`, можно задать ID из URL дашборда
# и вызывать: npx @railway/cli up -p $env:RAILWAY_PROJECT_ID -e production
# RAILWAY_PROJECT_ID=
# RAILWAY_ENVIRONMENT=production
