# Bitget HMAC (signed V2 isolated borrow limits + tier; без ключей — только UTA margin-loans).
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=

# Optional: POST max-borrowable per token (slow). Default off. На Railway — только если нужен персональный макс.
# BITGET_ACCOUNT_MAX_BORROW=1

# Client abort for /api/scan (ms). Default 120000.
# NEXT_PUBLIC_SCAN_TIMEOUT_MS=120000

# Тонкий клиент: этот инстанс только проксирует GET /api/scan с другого origin (например второй Railway-сервис).
# SCAN_UPSTREAM_URL=https://your-bitget-scanner.up.railway.app
# SCAN_UPSTREAM_TIMEOUT_MS=120000
