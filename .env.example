# Bitget HMAC (signed V2 isolated borrow limits + tier; без ключей — только UTA margin-loans).
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=

# Optional: POST max-borrowable per token (slow). Default off. На Railway — только если нужен персональный макс.
# BITGET_ACCOUNT_MAX_BORROW=1

# Client abort for /api/scan (ms). Default 120000.
# NEXT_PUBLIC_SCAN_TIMEOUT_MS=120000

# Тонкий клиент: этот инстанс только проксирует GET /api/scan с другого origin (например второй Railway-сервис).
# SCAN_UPSTREAM_URL=https://your-bitget-scanner.up.railway.app
# SCAN_UPSTREAM_TIMEOUT_MS=120000

# =============================================================================
# Outbound proxy (Railway / обход блокировок Binance & Bybit)
# =============================================================================
# Формат всегда: http://USER:PASS@HOST:PORT  (или https://… если провайдер так требует)
# Если провайдер дал host:port:user:pass → соберите URL: http://USER:PASS@HOST:PORT
#
# Рекомендуется: только Binance/Bybit через отдельный прокси (Gate и остальные — напрямую).
# Можно URL: http://USER:PASS@HOST:PORT  или короткая форма провайдера: HOST:PORT:USER:PASS
EXCHANGE_BINANCE_BYBIT_PROXY_URL=
#
# Опционально: весь исходящий трафик бирж через один прокси (в т.ч. Gate, если задано).
EXCHANGE_PROXY_URL=
# Альтернатива стандарту (если уже используете в системе):
# HTTPS_PROXY=
# HTTP_PROXY=

# Binance USDT-M futures: несколько fapi-хостов до ошибки (через пробел или запятую).
# BINANCE_FAPI_BASES=https://fapi.binance.com https://fapi1.binance.com https://fapi2.binance.com https://fapi3.binance.com

# Bybit: список origin по порядку (через пробел или запятую). По умолчанию: https://api.bybit.com
# BYBIT_API_BASES=https://api.bybit.com

# Gate borrow liquidity: по умолчанию только earn/uni/currencies × spot. Если нужен запасной
# «лимит пары» из margin (не реальный пул — часто круглые числа), включите:
# GATE_MARGIN_QUOTE_CAP_FALLBACK=1

# Логи ликвидности в консоль при сборке /api/scan (первые N токенов из списка Gate)
# SCAN_DEBUG_LIQUIDITY=1
# SCAN_DEBUG_LIQUIDITY_TOKENS=10
